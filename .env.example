# Copy to .env and fill from your Supabase project settings.
# Anon/publishable keys only — never commit service_role keys.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Payload CMS (public site reads content via REST API)
PAYLOAD_URL=http://localhost:3001
VITE_PAYLOAD_URL=http://localhost:3001

# Public site URL for SEO (canonical, sitemap, OG)
SITE_URL=https://realmedia.ink
VITE_SITE_URL=https://realmedia.ink

# Google Search Console verification meta tag (optional)
# VITE_GOOGLE_SITE_VERIFICATION=your-token-from-search-console
