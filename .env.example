# Copy to .env for local development.

# Payload CMS (public site reads content via REST API)
PAYLOAD_URL=http://localhost:3001
VITE_PAYLOAD_URL=http://localhost:3001

# Public site URL for SEO (canonical, sitemap, OG)
# Production default: https://rm-marketing-agency.vercel.app
# Custom domain: https://realmedia.ink
SITE_URL=https://rm-marketing-agency.vercel.app
VITE_SITE_URL=https://rm-marketing-agency.vercel.app

# Google Search Console verification meta tag (optional)
# VITE_GOOGLE_SITE_VERIFICATION=your-token-from-search-console

# Custom OG image URL (optional — defaults to /og.png)
# VITE_OG_IMAGE_URL=https://rm-marketing-agency.vercel.app/og.png
