# Payload CMS — copy to cms/.env

# Generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public URL of this CMS (used for media links and admin)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# PostgreSQL — local Docker (port 5433) or Supabase connection string
DATABASE_URL=postgresql://payload:payload@localhost:5433/payload

# Public marketing site origin (CORS)
FRONTEND_URL=http://localhost:5173

# Secret for Vercel cron → POST /api/jobs/run (Bearer token)
CRON_SECRET=change-me-cron-secret
